{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "types": ["node"],
    "typeRoots": ["./npm/node_modules/@types"],
    "paths": {
      "@earendil-works/pi-coding-agent": [
        "./npm/node_modules/@earendil-works/pi-coding-agent"
      ],
      "@earendil-works/pi-agent-core": [
        "./npm/node_modules/@earendil-works/pi-coding-agent/node_modules/@earendil-works/pi-agent-core"
      ],
      "@earendil-works/pi-ai": [
        "./npm/node_modules/@earendil-works/pi-coding-agent/node_modules/@earendil-works/pi-ai"
      ],
      "@earendil-works/pi-tui": [
        "./npm/node_modules/@earendil-works/pi-coding-agent/node_modules/@earendil-works/pi-tui"
      ],
      "typebox": [
        "./npm/node_modules/@earendil-works/pi-coding-agent/node_modules/typebox"
      ]
    }
  },
  "include": ["extensions/**/*.ts", "types/**/*.d.ts"]
}
