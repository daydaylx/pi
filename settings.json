{
  "lastChangelogVersion": "0.80.7",
  "theme": "aurora-night",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.6-terra",
  "hideThinkingBlock": true,
  "defaultThinkingLevel": "high",
  "thinkingBudgets": {
    "minimal": 1024,
    "low": 4096,
    "medium": 10240,
    "high": 32768,
    "xhigh": 100000
  },
  "quietStartup": true,
  "defaultProjectTrust": "ask",
  "collapseChangelog": true,
  "enableInstallTelemetry": false,
  "enabledModels": [
    "openai-codex/gpt-5.4-mini",
    "openai-codex/gpt-5.4",
    "openai-codex/gpt-5.5",
    "zai/glm-5.2",
    "zai/glm-4.7",
    "openrouter/tencent/hy3:free",
    "openrouter/poolside/laguna-m.1:free",
    "openrouter/openai/gpt-oss-20b:free",
    "opencode-go/qwen3.7-plus",
    "opencode-go/qwen3.7-max",
    "opencode-go/qwen3.6-plus",
    "opencode-go/minimax-m3",
    "opencode-go/minimax-m2.7",
    "opencode-go/mimo-v2.5-pro",
    "opencode-go/mimo-v2.5",
    "opencode-go/kimi-k2.7-code",
    "opencode-go/kimi-k2.6",
    "openai-codex/gpt-5.6-terra",
    "openai-codex/gpt-5.6-luna",
    "openai-codex/gpt-5.6-sol"
  ],
  "packages": [
    "git:github.com/daydaylx/pi-subagents@dd716cfc8c3a9b0ee35632752ac2b1736cd7de61"
  ],
  "extensions": [
    "!extensions/**",
    "+extensions/setup-core/index.ts",
    "+extensions/plan-mode/index.ts",
    "+extensions/mode-permissions.ts",
    "+extensions/ask-user.ts",
    "+extensions/lsp/index.ts",
    "+extensions/tool-output-guard.ts",
    "+extensions/aurora-ui/index.ts"
  ],
  "doubleEscapeAction": "tree",
  "treeFilterMode": "all",
  "editorPaddingX": 1,
  "autocompleteMaxVisible": 8,
  "compaction": {
    "enabled": true,
    "reserveTokens": 32768,
    "keepRecentTokens": 12000
  },
  "branchSummary": {
    "reserveTokens": 16384,
    "skipPrompt": true
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
    "provider": {
      "timeoutMs": 3600000,
      "maxRetries": 0,
      "maxRetryDelayMs": 60000
    }
  },
  "terminal": {
    "showImages": false,
    "showTerminalProgress": true
  },
  "images": {
    "blockImages": true
  },
  "showHardwareCursor": true
}