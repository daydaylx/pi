{
  "lastChangelogVersion": "0.80.6",
  "theme": "catppuccin-mocha",
  "defaultProvider": "zai",
  "defaultModel": "glm-5.2",
  "hideThinkingBlock": true,
  "defaultThinkingLevel": "high",
  "thinkingBudgets": {
    "minimal": 1024,
    "low": 4096,
    "medium": 10240,
    "high": 32768,
    "xhigh": 100000
  },
  "quietStartup": true,
  "defaultProjectTrust": "ask",
  "collapseChangelog": true,
  "enableInstallTelemetry": false,
  "enabledModels": [
    "zai/glm-5.2",
    "zai/glm-5-turbo",
    "openai-codex/gpt-5.4-mini",
    "openai-codex/gpt-5.4",
    "openai-codex/gpt-5.3-codex-spark",
    "openai-codex/gpt-5.5",
    "opencode-go/kimi-k2.6",
    "opencode-go/minimax-m3",
    "opencode-go/qwen3.7-max",
    "opencode-go/minimax-m2.7",
    "opencode-go/qwen3.6-plus",
    "opencode-go/deepseek-v4-flash",
    "opencode-go/qwen3.7-plus",
    "opencode-go/deepseek-v4-pro",
    "opencode-go/kimi-k2.7-code",
    "opencode-go/mimo-v2.5-pro",
    "opencode-go/mimo-v2.5",
    "openrouter/qwen/qwen3-coder:free",
    "openrouter/poolside/laguna-m.1:free"
  ],
  "packages": [
    "git:github.com/daydaylx/pi-zentui@06d23d5f2b12f9c49ee26a1c4d8ec776b2ef8adc",
    "git:github.com/daydaylx/pi-tool-display@4da62ca9f4fd72c61140e22a182a5069f9819084",
    "npm:@ujjwalgrover/pi-catppuccin@1.0.0",
    "git:github.com/daydaylx/pi-subagents@dd716cfc8c3a9b0ee35632752ac2b1736cd7de61"
  ],
  "extensions": [
    "!extensions/**",
    "+extensions/plan-mode/index.ts",
    "+extensions/mode-permissions.ts",
    "+extensions/activity-status.ts",
    "+extensions/ask-user.ts"
  ],
  "doubleEscapeAction": "tree",
  "treeFilterMode": "all",
  "editorPaddingX": 1,
  "autocompleteMaxVisible": 8,
  "compaction": {
    "enabled": true,
    "reserveTokens": 32768,
    "keepRecentTokens": 12000
  },
  "branchSummary": {
    "reserveTokens": 16384,
    "skipPrompt": true
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
    "provider": {
      "timeoutMs": 3600000,
      "maxRetries": 0,
      "maxRetryDelayMs": 60000
    }
  },
  "terminal": {
    "showImages": false,
    "showTerminalProgress": true
  },
  "images": {
    "blockImages": true
  },
  "showHardwareCursor": true
}