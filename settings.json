{
  "lastChangelogVersion": "0.80.3",
  "theme": "david-dark",
  "defaultProvider": "zai",
  "defaultModel": "glm-5.2",
  "hideThinkingBlock": false,
  "defaultThinkingLevel": "high",
  "thinkingBudgets": {
    "minimal": 1024,
    "low": 4096,
    "medium": 10240,
    "high": 32768,
    "xhigh": 100000
  },
  "quietStartup": true,
  "defaultProjectTrust": "ask",
  "collapseChangelog": true,
  "enableInstallTelemetry": false,
  "enabledModels": [
    "glm-5.2",
    "glm-5-turbo"
  ],
  "packages": [
    "npm:@zgltyq/pi-ask-user",
    "npm:pi-scroll",
    "npm:pi-markdown-preview",
    "npm:@zigai/pi-prompt-history"
  ],
  "extensions": [
    "!extensions/**",
    "+extensions/notify.ts",
    "+extensions/tools.ts",
    "+extensions/plan-mode/index.ts",
    "+extensions/git-guard.ts",
    "+extensions/bash-guard.ts",
    "+extensions/mode-switcher.ts"
  ],
  "doubleEscapeAction": "tree",
  "treeFilterMode": "all",
  "editorPaddingX": 1,
  "autocompleteMaxVisible": 8,
  "compaction": {
    "enabled": true,
    "reserveTokens": 32768,
    "keepRecentTokens": 12000
  },
  "branchSummary": {
    "reserveTokens": 16384,
    "skipPrompt": true
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
    "provider": {
      "timeoutMs": 3600000,
      "maxRetries": 0,
      "maxRetryDelayMs": 60000
    }
  },
  "terminal": {
    "showImages": false,
    "showTerminalProgress": true
  },
  "images": {
    "blockImages": true
  },
  "showHardwareCursor": true,
  "pi-scroll": {
    "defaultScope": "cwd",
    "defaultFilterMode": "chat",
    "preview": true,
    "previewMinWidth": 100
  }
}