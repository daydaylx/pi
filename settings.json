{
  "lastChangelogVersion": "0.80.6",
  "theme": "pi-vivid",
  "defaultProvider": "zai",
  "defaultModel": "glm-5.2",
  "hideThinkingBlock": true,
  "defaultThinkingLevel": "high",
  "thinkingBudgets": {
    "minimal": 1024,
    "low": 4096,
    "medium": 10240,
    "high": 32768,
    "xhigh": 100000
  },
  "quietStartup": true,
  "defaultProjectTrust": "ask",
  "collapseChangelog": true,
  "enableInstallTelemetry": false,
  "enabledModels": [
    "zai/glm-5.2",
    "zai/glm-5-turbo",
    "openai-codex/gpt-5.4-mini",
    "openai-codex/gpt-5.4",
    "openai-codex/gpt-5.3-codex-spark",
    "openai-codex/gpt-5.5",
    "opencode-go/kimi-k2.6",
    "opencode-go/minimax-m3",
    "opencode-go/qwen3.7-max",
    "opencode-go/minimax-m2.7",
    "opencode-go/qwen3.6-plus",
    "opencode-go/deepseek-v4-flash",
    "opencode-go/qwen3.7-plus",
    "opencode-go/deepseek-v4-pro",
    "opencode-go/kimi-k2.7-code",
    "opencode-go/mimo-v2.5-pro",
    "opencode-go/mimo-v2.5",
    "openrouter/qwen/qwen3-coder:free",
    "openrouter/poolside/laguna-m.1:free"
  ],
  "packages": [
    "npm:pi-scroll",
    "npm:pi-markdown-preview",
    "npm:@zigai/pi-prompt-history",
    {
      "source": "npm:pi-claude-style-tools@1.0.64",
      "extensions": [],
      "themes": []
    },
    "npm:pi-zentui@0.3.0"
  ],
  "extensions": [
    "!extensions/**",
    "+extensions/notify.ts",
    "+extensions/startup-banner.ts",
    "+extensions/preview-runtime.ts",
    "+extensions/tools.ts",
    "+extensions/plan-mode/index.ts",
    "+extensions/subagents/index.ts",
    "+extensions/mode-permissions.ts",
    "+extensions/ask-user.ts",
    "+extensions/ux-status.ts",
    "+extensions/actions.ts",
    "+extensions/working-visuals.ts",
    "+extensions/tool-visuals.ts",
    "+extensions/skill-mode/index.ts",
    "+extensions/activity-panel.ts"
  ],
  "doubleEscapeAction": "tree",
  "treeFilterMode": "all",
  "editorPaddingX": 1,
  "autocompleteMaxVisible": 8,
  "compaction": {
    "enabled": true,
    "reserveTokens": 32768,
    "keepRecentTokens": 12000
  },
  "branchSummary": {
    "reserveTokens": 16384,
    "skipPrompt": true
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
    "provider": {
      "timeoutMs": 3600000,
      "maxRetries": 0,
      "maxRetryDelayMs": 60000
    }
  },
  "terminal": {
    "showImages": false,
    "showTerminalProgress": true
  },
  "images": {
    "blockImages": true
  },
  "showHardwareCursor": true,
  "pi-scroll": {
    "defaultScope": "cwd",
    "defaultFilterMode": "chat",
    "preview": true,
    "previewMinWidth": 100
  }
}