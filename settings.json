{
  "lastChangelogVersion": "0.80.3",
  "theme": "david-dark",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "hideThinkingBlock": true,
  "defaultThinkingLevel": "high",
  "thinkingBudgets": {
    "minimal": 1024,
    "low": 4096,
    "medium": 10240,
    "high": 32768,
    "xhigh": 100000
  },
  "quietStartup": true,
  "defaultProjectTrust": "ask",
  "collapseChangelog": true,
  "enableInstallTelemetry": false,
  "enabledModels": [
    "zai/glm-5.2",
    "zai/glm-5-turbo",
    "openai-codex/gpt-5.4-mini",
    "openai-codex/gpt-5.4",
    "openai-codex/gpt-5.3-codex-spark",
    "openai-codex/gpt-5.5"
  ],
  "packages": [
    "npm:pi-scroll",
    "npm:pi-markdown-preview",
    "npm:@zigai/pi-prompt-history",
    {
      "source": "npm:pi-claude-style-tools@1.0.64",
      "extensions": [
        "extensions/index.ts"
      ],
      "themes": []
    },
    "npm:pi-zentui@0.3.0"
  ],
  "extensions": [
    "!extensions/**",
    "+extensions/notify.ts",
    "+extensions/preview-runtime.ts",
    "+extensions/tools.ts",
    "+extensions/plan-mode/index.ts",
    "+extensions/mode-permissions.ts",
    "+extensions/ask-user.ts",
    "+extensions/ux-status.ts",
    "+extensions/actions.ts"
  ],
  "doubleEscapeAction": "tree",
  "treeFilterMode": "all",
  "editorPaddingX": 1,
  "autocompleteMaxVisible": 8,
  "compaction": {
    "enabled": true,
    "reserveTokens": 32768,
    "keepRecentTokens": 12000
  },
  "branchSummary": {
    "reserveTokens": 16384,
    "skipPrompt": true
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
    "provider": {
      "timeoutMs": 3600000,
      "maxRetries": 0,
      "maxRetryDelayMs": 60000
    }
  },
  "terminal": {
    "showImages": false,
    "showTerminalProgress": true
  },
  "images": {
    "blockImages": true
  },
  "showHardwareCursor": true,
  "pi-scroll": {
    "defaultScope": "cwd",
    "defaultFilterMode": "chat",
    "preview": true,
    "previewMinWidth": 100
  }
}